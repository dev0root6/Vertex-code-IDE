{
  "name": "devx-devcode",
  "displayName": "DevX Code IDE",
  "description": "DevX Code IDE: The Visual Learning IDE with AI-Powered Insights",
  "version": "1.1.0",
  "publisher": "devx-dev",
  "icon": "DX-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dev0root6/DevX-code-IDE"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:c",
    "onLanguage:cpp",
    "onLanguage:java"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devx.resetApiKey",
        "title": "DevX: Reset Gemini API Key"
      },
      {
        "command": "devx.loadEnvKeys",
        "title": "DevX: Load API Keys from .env"
      },
      {
        "command": "devx.loadLesson",
        "title": "DevX: Load Sample Lesson"
      },
      {
        "command": "devx.clearLesson",
        "title": "DevX: Clear Lesson"
      },
      {
        "command": "devx.showVisualizer",
        "title": "DevX: Show Visual Intelligence"
      },
      {
        "command": "devx.runCode",
        "title": "DevX: Run Current Code"
      },
      {
        "command": "devx.askSensei",
        "title": "DevX: Ask Sensei for Code"
      },
      {
        "command": "devx.toggleVisualizer",
        "title": "DevX: Toggle Visual Intelligence"
      },
      {
        "command": "devx.selectModel",
        "title": "DevX: Select Gemini Model"
      },
      {
        "command": "devx.resetGeminiKey",
        "title": "DevX: Reset Gemini API Key",
        "category": "DevX"
      },
      {
        "command": "devx.resetOpenRouterKey",
        "title": "DevX: Reset OpenRouter API Key",
        "category": "DevX"
      },
      {
        "command": "devx.resetOllamaKey",
        "title": "DevX: Reset Ollama Cloud API Key",
        "category": "DevX"
      },
      {
        "command": "devx.resetAllKeys",
        "title": "DevX: Reset ALL API Keys",
        "category": "DevX"
      },
      {
        "command": "devx.changeLevel",
        "title": "DevX: Change Learning Level",
        "category": "DevX"
      },
      {
        "command": "devx.resetProfile",
        "title": "DevX: Reset Learning Profile",
        "category": "DevX"
      },
      {
        "command": "devx.viewStats",
        "title": "DevX: View Learning Statistics",
        "category": "DevX"
      },
      {
        "command": "devx.disabledAction",
        "title": "DevX: Disabled Action (Learning Mode)",
        "category": "DevX"
      },
      {
        "command": "devx.toggleTab",
        "title": "DevX: Toggle Tab Key (Hidden)"
      },
      {
        "command": "devx.requestGuidance",
        "title": "DevX: Request Learning Guidance"
      },
      {
        "command": "devx.openChat",
        "title": "💬 Chat with Sensei",
        "category": "DevX"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devx-explorer",
          "title": "DevX",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "devx-explorer": [
        {
          "type": "webview",
          "id": "devx.visualizer",
          "name": "Visual Intelligence",
          "icon": "$(graph-line)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "devx.senseiMessages",
          "name": "Sensei Messages",
          "icon": "$(comment-discussion)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "devx.blockCode",
          "name": "Block Code",
          "icon": "$(symbol-class)",
          "visibility": "visible"
        }
      ]
    },
    "keybindings": [
      {
        "command": "devx.askSensei",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "editorTextFocus"
      },
      {
        "command": "devx.toggleVisualizer",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus"
      },
      {
        "command": "devx.selectModel",
        "key": "ctrl+j",
        "mac": "cmd+j",
        "when": "editorTextFocus"
      },
      {
        "command": "devx.changeProvider",
        "key": "ctrl+h",
        "mac": "cmd+h",
        "when": "editorTextFocus"
      },
      {
        "command": "devx.disabledAction",
        "key": "tab",
        "when": "editorTextFocus && devx.locked && devx.level == 'beginner' && !suggestWidgetVisible && !inSnippetMode && !editorTabMovesFocus",
        "args": "tab"
      },
      {
        "command": "devx.disabledAction",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "editorTextFocus && devx.locked",
        "args": "copy"
      },
      {
        "command": "devx.disabledAction",
        "key": "ctrl+v",
        "mac": "cmd+v",
        "when": "editorTextFocus && devx.locked",
        "args": "paste"
      },
      {
        "command": "devx.disabledAction",
        "key": "ctrl+x",
        "mac": "cmd+x",
        "when": "editorTextFocus && devx.locked",
        "args": "cut"
      },
      {
        "command": "devx.toggleTab",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      }
    ],
    "configuration": {
      "title": "DevX",
      "properties": {
        "devx.aiProvider": {
          "type": "string",
          "default": "Gemini",
          "description": "Fallback provider if service-specific providers are not set.",
          "enum": [
            "Local Model (Ollama)",
            "Ollama Cloud",
            "OpenRouter",
            "Gemini"
          ]
        },
        "devx.senseiProvider": {
          "type": "string",
          "default": "Gemini",
          "description": "Provider specifically for Sensei's motivational feedback and insights.",
          "enum": [
            "Local Model (Ollama)",
            "Ollama Cloud",
            "OpenRouter",
            "Gemini"
          ]
        },
        "devx.senseiModel": {
          "type": "string",
          "description": "Model used by Sensei for mentoring."
        },
        "devx.codeGenProvider": {
          "type": "string",
          "default": "Gemini",
          "description": "Provider specifically for 'Ask Sensei' and auto-completions.",
          "enum": [
            "Local Model (Ollama)",
            "Ollama Cloud",
            "OpenRouter",
            "Gemini"
          ]
        },
        "devx.codeGenModel": {
          "type": "string",
          "description": "Model used for code generation."
        },
        "devx.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The endpoint for your Local Ollama instance."
        },
        "devx.ollamaModel": {
          "type": "string",
          "description": "The local model name to use with Ollama (e.g., llama3, gemma, mistral, phi3)."
        },
        "devx.geminiModel": {
          "type": "string",
          "description": "The Gemini model to use for Sensei's motivational feedback.",
          "enum": [
            "gemini-2.5-flash",
            "gemini-2.5-flash-lite",
            "gemini-2.5-pro",
            "gemini-2.0-flash",
            "gemini-2.0-flash-exp"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.0.2",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "blockly": "^12.4.1"
  }
}
